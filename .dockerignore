# ── Dockerignore for hosted-mode Breadbox image ───────────────────────────
#
# Keep the build context small: we only need source + lockfile + scripts.
# Everything generated, cached, or binary-built is reproduced inside the
# Dockerfile stages.

# Node/Bun deps — reinstalled inside the image
node_modules
**/node_modules

# Build outputs — regenerated
packages/app/dist
packages/cli/dist
packages/cli/src/web-ui-manifest.generated.ts

# Local developer state
.env
.env.local
.DS_Store
.idea
.vscode
.claude

# Data + caches that should not ship in the image (volume-mounted instead)
packages/api/data
.dreamer
.arduino15

# Git
.git
.github
.gitignore

# Docs we don't need in the image
docs
*.md

# Arduino LLM output
arduinoLLM
