+// PN-junction voltage limiting (SPICE3 DEVpnjlim). Damps the per-iteration
+// change in junction voltage so exp(vd/vt) can't overflow during Newton
+// iteration, while still converging to the true forward voltage. This replaces
+// a hard vd<=0.8V clamp that capped the operating point itself and made
+// realistic LED forward drops (red ~1.8V, blue ~3V) physically unreachable.
+function pnjLimit(vnew, vold, vt, vcrit) {
+  if (vnew > vcrit && Math.abs(vnew - vold) > 2 * vt) {
+    if (vold > 0) {
+      const arg = 1 + (vnew - vold) / vt;
+      vnew = arg > 0 ? vold + vt * Math.log(arg) : vcrit;
+    } else if (vnew > 0) {
+      vnew = vt * Math.log(vnew / vt);
+    }
+  }
+  return vnew;
+}
