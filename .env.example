# ── Breadbox dev env template ─────────────────────────────────────────────
#
# Copy to `.env` (gitignored) and fill in. Both Bun (API) and Vite (app)
# auto-load this file from the repo root.
#
# Breadbox runs in CLI mode (BREADBOX_MODE=cli, the default): file-based
# storage, single-tenant local user, no auth gate. The desktop app embeds
# the same server as a sidecar binary.

# ── Required for any dev run ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
