# ── Dreamer dev env template ─────────────────────────────────────────────
#
# Copy to `.env` (gitignored) and fill in. Both Bun (API) and Vite (app)
# auto-load this file from the repo root.
#
# Pick a path:
#   • Bypass auth in dev:   leave OAuth vars empty, run `bun run dev`
#   • Real OAuth in dev:    fill OAuth vars, run `bun run dev:hosted`

# ── Required for any dev run ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Required for `bun run dev:hosted` (real GitHub OAuth) ────────────────
#
# Register an OAuth app at https://github.com/settings/applications/new
#   Homepage URL:                http://localhost:3002
#   Authorization callback URL:  http://localhost:3002/api/auth/github/callback
#
# The callback URL must exactly match what the API reconstructs at
# /api/auth/github/start. Vite's proxy is patched (vite.config.ts) to
# forward X-Forwarded-Host so the API rebuilds it as :3002, not :4111.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated HMAC keys for signing OAuth `state`. Index 0 is the
# active signer; older entries verify only (key rotation). Generate with:
#   openssl rand -hex 32
AUTH_SECRETS=

# Public origin the browser hits. Used by the API for CORS + cookie
# domain reasoning in hosted mode. Match your Vite dev origin.
APP_ORIGIN=http://localhost:3002

# Optional: GitHub logins allowed to hit admin endpoints (project claim,
# etc). Comma-separated, no spaces.
ADMIN_GITHUB_LOGINS=
