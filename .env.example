# ── Dreamer dev env template ─────────────────────────────────────────────
#
# Copy to `.env` (gitignored) and fill in. Both Bun (API) and Vite (app)
# auto-load this file from the repo root.
#
# Two deploy modes:
#   • CLI mode  (DREAMER_MODE=cli, default for `bun run dev`):
#       File-based storage, auth bypassed (DREAMER_DEV_SKIP_AUTH=1).
#       No Supabase needed locally; SUPABASE_* can stay empty.
#   • Hosted   (DREAMER_MODE=hosted, used by `bun run dev:hosted`):
#       Supabase Auth (GitHub OAuth), Postgres-backed storage, Supabase
#       Storage for assets. Requires `bunx supabase start` (local) or a
#       Supabase Cloud project (prod).

# ── Required for any dev run ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Supabase (required in hosted mode) ───────────────────────────────────
#
# Local: defaults emitted by `bunx supabase start` (54321 is the default
# REST port). The anon + service-role keys are printed at startup and
# don't change between resets.
# Prod:  values from your Supabase Cloud project settings.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub OAuth (hosted mode only) ──────────────────────────────────────
#
# Register an OAuth app at https://github.com/settings/applications/new
#   Local dev (Supabase proxies the callback via 54321):
#     Homepage URL:                http://localhost:3002
#     Authorization callback URL:  http://127.0.0.1:54321/auth/v1/callback
#
# These are read by supabase/config.toml at `bunx supabase start`.
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=

# Public origin the browser hits. Used by the API for CORS reasoning in
# hosted mode. Match your Vite dev origin.
APP_ORIGIN=http://localhost:3002

# Optional: GitHub logins authorized to hit admin endpoints (project
# claim, etc). Comma-separated, no spaces. Hosted mode reads this from
# the JWT's user_metadata.user_name.
ADMIN_GITHUB_LOGINS=
