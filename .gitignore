node_modules
dist
# Env files — ignore every variant, but keep the committed templates.
.env
.env.*
!.env.example
!**/.env.example
bun.lock
arduinoLLM
# Local Claude Code state stays out of git, but the shared project skills are tracked.
.claude/*
!.claude/skills/

# Generated per-build — see scripts/generate-asset-manifest.ts
packages/cli/src/web-ui-manifest.generated.ts
packages/app/dist/
packages/cli/dist/
motionEditor

# Per-developer runtime state from `bun run dev` — projects, agent runs,
# threads, tests, and audit logs are rewritten on every server interaction
# and should not be committed. The directories are recreated on boot if
# missing; only the contents are ignored.
packages/api/data/projects/*.json
packages/api/data/runs/*.json
packages/api/data/threads/*.json
packages/api/data/tests/*.json
packages/api/data/audit/


# Playwright e2e
packages/app/test-results/
packages/app/playwright-report/
packages/app/.playwright/
