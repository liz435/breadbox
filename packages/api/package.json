{
  "name": "@dreamer/api",
  "version": "0.0.1",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./*/": "./src/*/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test src",
    "benchmark:agent": "bun run src/eval/benchmark-runner.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@dreamer/config": "workspace:*",
    "@dreamer/schemas": "workspace:*",
    "@elysiajs/cors": "^1.3.0",
    "@sinclair/typebox": "^0.34.48",
    "ai": "^6.0.0",
    "elysia": "^1.3.0",
    "ts-pattern": "^5.9.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.9",
    "typescript": "^5.7.0"
  }
}
