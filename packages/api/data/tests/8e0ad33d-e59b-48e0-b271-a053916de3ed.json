      {
        "step": 40,
        "type": "tool_call",
        "toolName": "add_component",
        "toolCallId": "toolu_01RrQBgicsUKJgVt2To9Cu23",
        "toolInput": {
          "entityId": "ed391c2d-7b6d-4780-8025-bd545e515538",
          "componentType": "sprite",
          "value": {
            "width": 20,
            "height": 30,
            "color": "#FF0000",
            "script": "let velocityY = 0;\nlet velocityX = 0;\nlet isGrounded = false;\nlet coinsCollected = 0;\nlet lives = 3;\nconst moveSpeed = 5;\nconst jumpPower = 15;\nconst platformData = {\n  'Ground': {x: 0, y: 280, w: 800, h: 40},\n  'Platform1': {x: -150, y: 180, w: 200, h: 20},\n  'Platform2': {x: 150, y: 180, w: 200, h: 20},\n  'Platform3': {x: 0, y: 80, w: 200, h: 20}\n};\n\n// Input\nlet moveX = 0;\nif (Input.isKeyPressed('a')) moveX -= moveSpeed;\nif (Input.isKeyPressed('d')) moveX += moveSpeed;\nvelocityX = moveX;\n\n// Jump\nif (Input.isKeyPressed(' ') && isGrounded) {\n  velocityY = -jumpPower;\n  isGrounded = false;\n}\n\n// Apply gravity\nvelocityY += 0.5;\n\n// Update position\nself.x += velocityX;\nself.y += velocityY;\n\n// Collision with platforms\nisGrounded = false;\nfor (let platformName in platformData) {\n  const p = platformData[platformName];\n  const px = p.x;\n  const py = p.y;\n  const pw = p.w;\n  const ph = p.h;\n  const playerW = 20;\n  const playerH = 30;\n  \n  if (self.x + playerW/2 > px - pw/2 && \n      self.x - playerW/2 < px + pw/2 &&\n      self.y + playerH/2 > py - ph/2 &&\n      self.y - playerH/2 < py + ph/2) {\n    // Landing on top\n    if (velocityY > 0 && self.y + playerH/2 - velocityY <= py - ph/2) {\n      self.y = py - ph/2 - playerH/2;\n      velocityY = 0;\n      isGrounded = true;\n    }\n  }\n}\n\n// Boundary check - fall off screen\nif (self.y > 400) {\n  lives -= 1;\n  if (lives <= 0) {\n    state.gameOver = true;\n  }\n  self.x = 0;\n  self.y = 150;\n  velocityY = 0;\n}\n\n// Check coin collisions\nfor (let i = 1; i <= 5; i++) {\n  const coinName = 'Coin' + i;\n  const coin = entities.get(coinName);\n  if (coin) {\n    const dx = coin.x - self.x;\n    const dy = coin.y - self.y;\n    const distance = Math.sqrt(dx*dx + dy*dy);\n    if (distance < 20) {\n      coinsCollected += 1;\n      coin.collected = true;\n      entities.delete(coinName);\n    }\n  }\n}\n\n// Check goomba collisions\nfor (let i = 1; i <= 3; i++) {\n  const goombaName = 'Goomba' + i;\n  const goomba = entities.get(goombaName);\n  if (goomba) {\n    const dx = goomba.x - self.x;\n    const dy = goomba.y - self.y;\n    const distance = Math.sqrt(dx*dx + dy*dy);\n    if (distance < 25) {\n      lives -= 1;\n      if (lives <= 0) {\n        state.gameOver = true;\n      }\n      self.x = 0;\n      self.y = 150;\n      velocityY = 0;\n    }\n  }\n}\n\n// Update UI\nconst ui = entities.get('UI');\nif (ui) {\n  ui.text = 'Coins: ' + coinsCollected + ' | Lives: ' + lives;\n}"
          }
