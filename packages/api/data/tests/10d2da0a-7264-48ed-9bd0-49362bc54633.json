          "sketch": "void setup() {\n  pinMode(13, OUTPUT);  // Top\n  pinMode(12, OUTPUT);  // Upper Left\n  pinMode(11, OUTPUT);  // Upper Right\n  pinMode(10, OUTPUT);  // Lower Left\n  pinMode(9, OUTPUT);   // Lower Right\n}\n\nvoid loop() {\n  // All LEDs ON - starfish glows!\n  digitalWrite(13, HIGH);\n  digitalWrite(12, HIGH);\n  digitalWrite(11, HIGH);\n  digitalWrite(10, HIGH);\n  digitalWrite(9, HIGH);\n  delay(500);\n  \n  // All LEDs OFF\n  digitalWrite(13, LOW);\n  digitalWrite(12, LOW);\n  digitalWrite(11, LOW);\n  digitalWrite(10, LOW);\n  digitalWrite(9, LOW);\n  delay(500);\n}"
