          "sketchCode": "// Starfish LED Circuit\n// 5 arms: Top, Top-Right, Bottom-Right, Bottom-Left, Top-Left\nint pins[] = {9, 10, 11, 12, 13};\n\nvoid setup() {\n  for (int i = 0; i < 5; i++) {\n    pinMode(pins[i], OUTPUT);\n  }\n}\n\n// Ripple outward from center — one arm at a time (clockwise)\nvoid ripple() {\n  for (int i = 0; i < 5; i++) {\n    digitalWrite(pins[i], HIGH);\n    delay(150);\n    digitalWrite(pins[i], LOW);\n    delay(50);\n  }\n}\n\n// All arms flash together\nvoid allFlash(int times) {\n  for (int t = 0; t < times; t++) {\n    for (int i = 0; i < 5; i++) digitalWrite(pins[i], HIGH);\n    delay(200);\n    for (int i = 0; i < 5; i++) digitalWrite(pins[i], LOW);\n    delay(200);\n  }\n}\n\n// Twinkle: random arms blink\nvoid twinkle() {\n  for (int t = 0; t < 15; t++) {\n    int arm = random(0, 5);\n    digitalWrite(pins[arm], HIGH);\n    delay(100);\n    digitalWrite(pins[arm], LOW);\n    delay(50);\n  }\n}\n\nvoid loop() {\n  ripple();       // Wave around the starfish arms\n  ripple();\n  ripple();\n  allFlash(3);    // All arms flash 3 times\n  twinkle();      // Random twinkling\n  allFlash(2);    // Final flash\n  delay(500);\n}\n"
        },
        "succeeded": true
