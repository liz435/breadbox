        "toolInput": {
          "type": "sprite",
          "name": "Player",
          "x": 0,
          "y": 0,
          "data": {
            "tint": "#FF0000",
            "sceneX": 0,
            "sceneY": 150,
            "width": 20,
            "height": 30,
            "script": "const SPEED = 200;\nconst GRAVITY = 500;\nconst JUMP_POWER = 300;\nconst GROUND_Y = 250; // Approximate ground level\n\nif (!state.playerVelocityY) state.playerVelocityY = 0;\nif (!state.isJumping) state.isJumping = false;\nif (!state.coins) state.coins = 0;\nif (!state.lives) state.lives = 3;\n\n// Horizontal movement\nlet moveX = 0;\nif (Input.isKeyPressed('a') || Input.isKeyPressed('A')) moveX = -SPEED;\nif (Input.isKeyPressed('d') || Input.isKeyPressed('D')) moveX = SPEED;\nself.x += moveX * dt;\n\n// Apply gravity\nstate.playerVelocityY += GRAVITY * dt;\nself.y += state.playerVelocityY * dt;\n\n// Platform collision detection\nlet platforms = [\n  { x: 0, y: 280, w: 800, h: 40 },     // Main ground\n  { x: -150, y: 180, w: 200, h: 20 },  // Platform 1\n  { x: 150, y: 180, w: 200, h: 20 },   // Platform 2\n  { x: 0, y: 80, w: 200, h: 20 }       // Platform 3\n];\n\nlet isOnGround = false;\nfor (let p of platforms) {\n  // Check if player is above platform and falling\n  if (state.playerVelocityY >= 0 &&\n      self.y + 15 >= p.y - 5 && // Player bottom touching platform top\n      self.y + 15 <= p.y + p.h + 5 &&\n      self.x + 10 > p.x - p.w/2 &&\n      self.x - 10 < p.x + p.w/2) {\n    self.y = p.y - 15;\n    state.playerVelocityY = 0;\n    state.isJumping = false;\n    isOnGround = true;\n  }\n}\n\n// Jump\nif ((Input.isKeyPressed(' ') || Input.isKeyPressed('Space')) && !state.isJumping && isOnGround) {\n  state.playerVelocityY = -JUMP_POWER;\n  state.isJumping = true;\n}\n\n// Goomba collision detection (game over)\nlet goombaList = ['Goomba_1', 'Goomba_2', 'Goomba_3'];\nfor (let gName of goombaList) {\n  let goomba = entities.get(gName);\n  if (goomba) {\n    let dx = self.x - goomba.x;\n    let dy = self.y - goomba.y;\n    let dist = Math.sqrt(dx*dx + dy*dy);\n    if (dist < 25) {\n      state.lives -= 1;\n      if (state.lives > 0) {\n        // Reset player position\n        self.x = 0;\n        self.y = 150;\n        state.playerVelocityY = 0;\n      }\n    }\n  }\n}\n\n// Coin collection\nlet coinList = ['Coin_1', 'Coin_2', 'Coin_3', 'Coin_4', 'Coin_5'];\nfor (let cName of coinList) {\n  let coin = entities.get(cName);\n  if (coin && coin.visible) {\n    let dx = self.x - coin.x;\n    let dy = self.y - coin.y;\n    let dist = Math.sqrt(dx*dx + dy*dy);\n    if (dist < 20) {\n      state.coins += 1;\n      coin.visible = false;\n    }\n  }\n}\n\n// Screen bounds\nif (self.x > 420) self.x = -420;\nif (self.x < -420) self.x = 420;\n"
          }
        }
