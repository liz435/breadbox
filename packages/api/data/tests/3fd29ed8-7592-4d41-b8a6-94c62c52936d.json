          "sketch": "int counter = 0;\nint btnPin = 9;\nint lastBtnState = HIGH;\n\n// Segment pins: a, b, c, d, e, f, g\nint segPins[7] = {2, 3, 4, 5, 6, 7, 8};\n\n// Digit lookup table: which segments light up for digits 0–9\n// Format: {a, b, c, d, e, f, g}\n// 1 = segment ON, 0 = segment OFF\n\nvoid displayDigit(int digit) {\n  if (digit == 0) {\n    int segs[7] = {1, 1, 1, 1, 1, 1, 0};\n    for (int i = 0; i < 7; i++) digitalWrite(segPins[i], segs[i]);\n  } else if (digit == 1) {\n    int segs[7] = {0, 1, 1, 0, 0, 0, 0};\n    for (int i = 0; i < 7; i++) digitalWrite(segPins[i], segs[i]);\n  } else if (digit == 2) {\n    int segs[7] = {1, 1, 0, 1, 1, 0, 1};\n    for (int i = 0; i < 7; i++) digitalWrite(segPins[i], segs[i]);\n  } else if (digit == 3) {\n    int segs[7] = {1, 1, 1, 1, 0, 0, 1};\n    for (int i = 0; i < 7; i++) digitalWrite(segPins[i], segs[i]);\n  } else if (digit == 4) {\n    int segs[7] = {0, 1, 1, 0, 0, 1, 1};\n    for (int i = 0; i < 7; i++) digitalWrite(segPins[i], segs[i]);\n  } else if (digit == 5) {\n    int segs[7] = {1, 0, 1, 1, 0, 1, 1};\n    for (int i = 0; i < 7; i++) digitalWrite(segPins[i], segs[i]);\n  } else if (digit == 6) {\n    int segs[7] = {1, 0, 1, 1, 1, 1, 1};\n    for (int i = 0; i < 7; i++) digitalWrite(segPins[i], segs[i]);\n  } else if (digit == 7) {\n    int segs[7] = {1, 1, 1, 0, 0, 0, 0};\n    for (int i = 0; i < 7; i++) digitalWrite(segPins[i], segs[i]);\n  } else if (digit == 8) {\n    int segs[7] = {1, 1, 1, 1, 1, 1, 1};\n    for (int i = 0; i < 7; i++) digitalWrite(segPins[i], segs[i]);\n  } else if (digit == 9) {\n    int segs[7] = {1, 1, 1, 1, 0, 1, 1};\n    for (int i = 0; i < 7; i++) digitalWrite(segPins[i], segs[i]);\n  }\n}\n\nvoid setup() {\n  pinMode(btnPin, INPUT_PULLUP);\n  for (int i = 0; i < 7; i++) {\n    pinMode(segPins[i], OUTPUT);\n  }\n  displayDigit(0);\n}\n\nvoid loop() {\n  int btnState = digitalRead(btnPin);\n  \n  // Button pressed (active LOW)\n  if (btnState == LOW && lastBtnState == HIGH) {\n    counter++;\n    if (counter > 9) counter = 0;  // Wrap around at 10\n    displayDigit(counter);\n    delay(50);  // Debounce\n  }\n  \n  lastBtnState = btnState;\n}\n"
        }
