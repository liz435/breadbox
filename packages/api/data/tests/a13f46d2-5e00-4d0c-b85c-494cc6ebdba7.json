    "sketch": "\n// ⭐ Starfish Blink — 6 LEDs all on Pin 8\n// Shape:\n//\n//         [Top Arm]\n//    [LUp]  [Center]  [RUp]\n//    [LDn]            [RDn]\n//\n// 1 Center LED + 5 Arm tip LEDs = Starfish!\n\nconst int LED_PIN = 8;\n\nvoid setup() {\n  pinMode(LED_PIN, OUTPUT);\n}\n\nvoid loop() {\n  // All LEDs ON — starfish glows!\n  digitalWrite(LED_PIN, HIGH);\n  delay(600);\n\n  // All LEDs OFF\n  digitalWrite(LED_PIN, LOW);\n  delay(400);\n}\n"
  },
