      "kind": "update_sketch",
      "payload": {
        "code": "// 7-segment counter with 1 button for incrementing\n// Display segments: a=D2, b=D3, c=D4, d=D5, e=D6, f=D7, g=D8\n// Button: D9 (INPUT_PULLUP, active LOW)\n\nint segmentPins[7] = {2, 3, 4, 5, 6, 7, 8};  // a, b, c, d, e, f, g\nint buttonPin = 9;\nint counter = 0;\nint lastButtonState = HIGH;\n\n// Segment patterns for digits 0-9\n// Each row represents which segments light up (1=on, 0=off)\nvoid displayDigit(int digit) {\n  int patterns[10][7] = {\n    {1, 1, 1, 1, 1, 1, 0},  // 0: a,b,c,d,e,f\n    {0, 1, 1, 0, 0, 0, 0},  // 1: b,c\n    {1, 1, 0, 1, 1, 0, 1},  // 2: a,b,d,e,g\n    {1, 1, 1, 1, 0, 0, 1},  // 3: a,b,c,d,g\n    {0, 1, 1, 0, 0, 1, 1},  // 4: b,c,f,g\n    {1, 0, 1, 1, 0, 1, 1},  // 5: a,c,d,f,g\n    {1, 0, 1, 1, 1, 1, 1},  // 6: a,c,d,e,f,g\n    {1, 1, 1, 0, 0, 0, 0},  // 7: a,b,c\n    {1, 1, 1, 1, 1, 1, 1},  // 8: all\n    {1, 1, 1, 1, 0, 1, 1}   // 9: a,b,c,d,f,g\n  };\n  \n  for (int i = 0; i < 7; i++) {\n    digitalWrite(segmentPins[i], patterns[digit][i]);\n  }\n}\n\nvoid setup() {\n  pinMode(buttonPin, INPUT_PULLUP);\n  for (int i = 0; i < 7; i++) {\n    pinMode(segmentPins[i], OUTPUT);\n  }\n  displayDigit(0);  // Show 0 initially\n}\n\nvoid loop() {\n  int buttonState = digitalRead(buttonPin);\n  \n  // Detect button press (HIGH to LOW transition)\n  if (buttonState == LOW && lastButtonState == HIGH) {\n    counter = (counter + 1) % 10;  // Increment and wrap at 10\n    displayDigit(counter);\n    delay(20);  // Debounce\n  }\n  \n  lastButtonState = buttonState;\n  delay(10);\n}\n"
      }
    }
  ],
