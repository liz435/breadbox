      "payload": {
        "code": "// Two LEDs + Pushbutton Demo\n// LED1 (Red)  -> D12 via 220Ω\n// LED2 (Blue) -> D11 via 220Ω\n// BTN1        -> D2  with 10kΩ pull-down\n\nconst int LED1_PIN  = 12;\nconst int LED2_PIN  = 11;\nconst int BTN_PIN   =  2;\n\nvoid setup() {\n  pinMode(LED1_PIN, OUTPUT);\n  pinMode(LED2_PIN, OUTPUT);\n  pinMode(BTN_PIN,  INPUT);   // pull-down resistor keeps this LOW when not pressed\n  digitalWrite(LED1_PIN, LOW);\n  digitalWrite(LED2_PIN, LOW);\n}\n\nvoid loop() {\n  bool btnPressed = digitalRead(BTN_PIN) == HIGH;\n\n  if (!btnPressed) {\n    // Idle: blink LED1 slowly, LED2 off\n    digitalWrite(LED1_PIN, HIGH);\n    digitalWrite(LED2_PIN, LOW);\n    delay(700);\n    digitalWrite(LED1_PIN, LOW);\n    delay(700);\n  } else {\n    // Button held: both LEDs on solid\n    digitalWrite(LED1_PIN, HIGH);\n    digitalWrite(LED2_PIN, HIGH);\n    delay(50);   // small debounce dwell\n  }\n}"
      }
    }
