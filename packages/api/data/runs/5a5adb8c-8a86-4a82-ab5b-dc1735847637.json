            "sketch": "int pinA = 2, pinB = 3, pinC = 4, pinD = 5, pinE = 6, pinF = 7, pinG = 8;\nint btnPin = 9;\nint counter = 0;\nint lastBtnState = HIGH;\nunsigned long lastPressTime = 0;\n\nvoid setup() {\n  pinMode(pinA, OUTPUT);\n  pinMode(pinB, OUTPUT);\n  pinMode(pinC, OUTPUT);\n  pinMode(pinD, OUTPUT);\n  pinMode(pinE, OUTPUT);\n  pinMode(pinF, OUTPUT);\n  pinMode(pinG, OUTPUT);\n  pinMode(btnPin, INPUT_PULLUP);\n  displayDigit(counter);\n}\n\nvoid loop() {\n  int btnState = digitalRead(btnPin);\n  \n  if (btnState == LOW && lastBtnState == HIGH) {\n    unsigned long currentTime = millis();\n    if (currentTime - lastPressTime > 200) {\n      counter = (counter + 1) % 10;\n      displayDigit(counter);\n      lastPressTime = currentTime;\n    }\n  }\n  \n  lastBtnState = btnState;\n}\n\nvoid displayDigit(int digit) {\n  int a, b, c, d, e, f, g;\n  a = b = c = d = e = f = g = LOW;\n  \n  if (digit == 0) { a = HIGH; b = HIGH; c = HIGH; d = HIGH; e = HIGH; f = HIGH; g = LOW; }\n  else if (digit == 1) { a = LOW; b = HIGH; c = HIGH; d = LOW; e = LOW; f = LOW; g = LOW; }\n  else if (digit == 2) { a = HIGH; b = HIGH; c = LOW; d = HIGH; e = HIGH; f = LOW; g = HIGH; }\n  else if (digit == 3) { a = HIGH; b = HIGH; c = HIGH; d = HIGH; e = LOW; f = LOW; g = HIGH; }\n  else if (digit == 4) { a = LOW; b = HIGH; c = HIGH; d = LOW; e = LOW; f = HIGH; g = HIGH; }\n  else if (digit == 5) { a = HIGH; b = LOW; c = HIGH; d = HIGH; e = LOW; f = HIGH; g = HIGH; }\n  else if (digit == 6) { a = HIGH; b = LOW; c = HIGH; d = HIGH; e = HIGH; f = HIGH; g = HIGH; }\n  else if (digit == 7) { a = HIGH; b = HIGH; c = HIGH; d = LOW; e = LOW; f = LOW; g = LOW; }\n  else if (digit == 8) { a = HIGH; b = HIGH; c = HIGH; d = HIGH; e = HIGH; f = HIGH; g = HIGH; }\n  else if (digit == 9) { a = HIGH; b = HIGH; c = HIGH; d = HIGH; e = LOW; f = HIGH; g = HIGH; }\n  \n  digitalWrite(pinA, a);\n  digitalWrite(pinB, b);\n  digitalWrite(pinC, c);\n  digitalWrite(pinD, d);\n  digitalWrite(pinE, e);\n  digitalWrite(pinF, f);\n  digitalWrite(pinG, g);\n}\n",
