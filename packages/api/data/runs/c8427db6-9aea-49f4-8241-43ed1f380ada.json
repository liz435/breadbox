            "code": "\n// ⭐ Starfish Blink — Button Triggered\n// Shape:\n//\n//         [Top Arm]\n//    [LUp]  [Center]  [RUp]\n//    [LDn]            [RDn]\n//\n// Press the button to toggle the starfish blink ON/OFF!\n// Button on D2 (INPUT_PULLUP) — press = LOW\n\nconst int LED_PIN    = 8;\nconst int BUTTON_PIN = 2;\n\nbool blinking        = false;\nbool lastButtonState = true;   // HIGH = not pressed (INPUT_PULLUP)\nbool ledsOn          = false;\n\nunsigned long lastBlinkTime = 0;\nconst unsigned long ON_TIME  = 600;\nconst unsigned long OFF_TIME = 400;\n\nvoid setup() {\n  pinMode(LED_PIN,    OUTPUT);\n  pinMode(BUTTON_PIN, INPUT_PULLUP);\n  digitalWrite(LED_PIN, LOW);\n}\n\nvoid loop() {\n  // --- Button toggle (edge detect) ---\n  bool currentButton = digitalRead(BUTTON_PIN);\n\n  if (lastButtonState == true && currentButton == false) {\n    // Falling edge = button just pressed\n    blinking = !blinking;\n    if (!blinking) {\n      digitalWrite(LED_PIN, LOW);\n      ledsOn = false;\n    }\n    delay(50); // simple debounce\n  }\n  lastButtonState = currentButton;\n\n  // --- Non-blocking blink ---\n  if (blinking) {\n    unsigned long now      = millis();\n    unsigned long interval = ledsOn ? ON_TIME : OFF_TIME;\n    if (now - lastBlinkTime >= interval) {\n      ledsOn = !ledsOn;\n      digitalWrite(LED_PIN, ledsOn ? HIGH : LOW);\n      lastBlinkTime = now;\n    }\n  }\n}\n"
