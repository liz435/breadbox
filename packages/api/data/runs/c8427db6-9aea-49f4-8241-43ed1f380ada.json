            "code": "\n// Starfish Blink — Button Triggered\n// Press button (D2) to toggle all 6 starfish LEDs blinking ON/OFF\n\nconst int LED_PIN    = 8;\nconst int BUTTON_PIN = 2;\n\nint blinking        = 0;\nint lastButtonState = 1;\nint ledsOn          = 0;\n\nunsigned long lastBlinkTime = 0;\n\nvoid setup() {\n  pinMode(LED_PIN,    OUTPUT);\n  pinMode(BUTTON_PIN, INPUT_PULLUP);\n  digitalWrite(LED_PIN, LOW);\n}\n\nvoid loop() {\n  int currentButton = digitalRead(BUTTON_PIN);\n\n  if (lastButtonState == 1 && currentButton == 0) {\n    if (blinking == 0) {\n      blinking = 1;\n    } else {\n      blinking = 0;\n      digitalWrite(LED_PIN, LOW);\n      ledsOn = 0;\n    }\n    delay(50);\n  }\n  lastButtonState = currentButton;\n\n  if (blinking == 1) {\n    unsigned long now = millis();\n    unsigned long interval = 600;\n    if (ledsOn == 0) {\n      interval = 400;\n    }\n    if (now - lastBlinkTime >= interval) {\n      if (ledsOn == 0) {\n        ledsOn = 1;\n        digitalWrite(LED_PIN, HIGH);\n      } else {\n        ledsOn = 0;\n        digitalWrite(LED_PIN, LOW);\n      }\n      lastBlinkTime = now;\n    }\n  }\n}\n"
