        "code": "\n// === Button Counter — 7-Segment Display ===\n// Common-cathode: HIGH = segment ON\n\nconst int SEG_A = 2;\nconst int SEG_B = 3;\nconst int SEG_C = 4;\nconst int SEG_D = 5;\nconst int SEG_E = 6;\nconst int SEG_F = 7;\nconst int SEG_G = 8;\nconst int BTN_PIN = 9;\n\nint count = 0;\nint lastBtnState = HIGH;\n\n// Display a single digit 0-9\n// segments: a b c d e f g\nvoid showDigit(int n) {\n  int a, b, c, d, e, f, g;\n  if (n == 0) { a=1; b=1; c=1; d=1; e=1; f=1; g=0; }\n  else if (n == 1) { a=0; b=1; c=1; d=0; e=0; f=0; g=0; }\n  else if (n == 2) { a=1; b=1; c=0; d=1; e=1; f=0; g=1; }\n  else if (n == 3) { a=1; b=1; c=1; d=1; e=0; f=0; g=1; }\n  else if (n == 4) { a=0; b=1; c=1; d=0; e=0; f=1; g=1; }\n  else if (n == 5) { a=1; b=0; c=1; d=1; e=0; f=1; g=1; }\n  else if (n == 6) { a=1; b=0; c=1; d=1; e=1; f=1; g=1; }\n  else if (n == 7) { a=1; b=1; c=1; d=0; e=0; f=0; g=0; }\n  else if (n == 8) { a=1; b=1; c=1; d=1; e=1; f=1; g=1; }\n  else             { a=1; b=1; c=1; d=1; e=0; f=1; g=1; } // 9\n  digitalWrite(SEG_A, a);\n  digitalWrite(SEG_B, b);\n  digitalWrite(SEG_C, c);\n  digitalWrite(SEG_D, d);\n  digitalWrite(SEG_E, e);\n  digitalWrite(SEG_F, f);\n  digitalWrite(SEG_G, g);\n}\n\nvoid setup() {\n  pinMode(SEG_A, OUTPUT);\n  pinMode(SEG_B, OUTPUT);\n  pinMode(SEG_C, OUTPUT);\n  pinMode(SEG_D, OUTPUT);\n  pinMode(SEG_E, OUTPUT);\n  pinMode(SEG_F, OUTPUT);\n  pinMode(SEG_G, OUTPUT);\n  pinMode(BTN_PIN, INPUT_PULLUP);\n  showDigit(0);\n}\n\nvoid loop() {\n  int btnState = digitalRead(BTN_PIN);\n  // Detect falling edge (button pressed)\n  if (btnState == LOW && lastBtnState == HIGH) {\n    delay(50); // debounce\n    count = (count + 1) % 10;\n    showDigit(count);\n  }\n  lastBtnState = btnState;\n}\n"
      }
