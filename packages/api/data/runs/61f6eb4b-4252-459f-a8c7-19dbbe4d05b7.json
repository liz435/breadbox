    {
      "opId": "eef9311f-f1f8-4af3-9e4f-c81251fd8def",
      "projectId": "6a10856f-bc23-46d6-8894-c1efdc15068f",
      "sceneId": "6d229581-a6d1-498c-af86-d6f03ce2d311",
