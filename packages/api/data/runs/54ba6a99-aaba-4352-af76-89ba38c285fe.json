          "input": {
            "board": "arduino_uno",
            "sketch": "int count = 0;\nint btnPin = 9;\nint lastBtnState = HIGH;\n\nint segPins[7] = {2, 3, 4, 5, 6, 7, 8};\n\nvoid setup() {\n  pinMode(btnPin, INPUT_PULLUP);\n  for (int i = 0; i < 7; i++) {\n    pinMode(segPins[i], OUTPUT);\n  }\n  displayDigit(0);\n}\n\nvoid loop() {\n  int btnState = digitalRead(btnPin);\n  \n  if (btnState == LOW && lastBtnState == HIGH) {\n    count = (count + 1) % 10;\n    displayDigit(count);\n    delay(20);\n  }\n  \n  lastBtnState = btnState;\n  delay(10);\n}\n\nvoid displayDigit(int digit) {\n  if (digit == 0) {\n    setSegments(1, 1, 1, 1, 1, 1, 0);\n  } else if (digit == 1) {\n    setSegments(0, 1, 1, 0, 0, 0, 0);\n  } else if (digit == 2) {\n    setSegments(1, 1, 0, 1, 1, 0, 1);\n  } else if (digit == 3) {\n    setSegments(1, 1, 1, 1, 0, 0, 1);\n  } else if (digit == 4) {\n    setSegments(0, 1, 1, 0, 0, 1, 1);\n  } else if (digit == 5) {\n    setSegments(1, 0, 1, 1, 0, 1, 1);\n  } else if (digit == 6) {\n    setSegments(1, 0, 1, 1, 1, 1, 1);\n  } else if (digit == 7) {\n    setSegments(1, 1, 1, 0, 0, 0, 0);\n  } else if (digit == 8) {\n    setSegments(1, 1, 1, 1, 1, 1, 1);\n  } else if (digit == 9) {\n    setSegments(1, 1, 1, 1, 0, 1, 1);\n  }\n}\n\nvoid setSegments(int a, int b, int c, int d, int e, int f, int g) {\n  digitalWrite(segPins[0], a);\n  digitalWrite(segPins[1], b);\n  digitalWrite(segPins[2], c);\n  digitalWrite(segPins[3], d);\n  digitalWrite(segPins[4], e);\n  digitalWrite(segPins[5], f);\n  digitalWrite(segPins[6], g);\n}",
