            "sketch": "\n// 7-Segment Counter (0–9) with Button\n// Common-Cathode 7-segment display\n// Segments: a=D2, b=D3, c=D4, d=D5, e=D6, f=D7, g=D8\n// Button: D9 (INPUT_PULLUP, active LOW)\n\nconst int segPins[7] = {2, 3, 4, 5, 6, 7, 8}; // a,b,c,d,e,f,g\nconst int btnPin = 9;\n\n// Common-cathode segment patterns for digits 0-9\n// Bit order: a,b,c,d,e,f,g\nconst byte digits[10] = {\n  0b1111110, // 0: a,b,c,d,e,f\n  0b0110000, // 1: b,c\n  0b1101101, // 2: a,b,d,e,g\n  0b1111001, // 3: a,b,c,d,g\n  0b0110011, // 4: b,c,f,g\n  0b1011011, // 5: a,c,d,f,g\n  0b1011111, // 6: a,c,d,e,f,g\n  0b1110000, // 7: a,b,c\n  0b1111111, // 8: a,b,c,d,e,f,g\n  0b1111011  // 9: a,b,c,d,f,g\n};\n\nint count = 0;\nbool lastBtnState = HIGH;\nunsigned long lastDebounceTime = 0;\nconst unsigned long debounceDelay = 50;\n\nvoid showDigit(int n) {\n  byte pattern = digits[n];\n  for (int i = 0; i < 7; i++) {\n    digitalWrite(segPins[i], (pattern >> (6 - i)) & 1);\n  }\n}\n\nvoid setup() {\n  for (int i = 0; i < 7; i++) {\n    pinMode(segPins[i], OUTPUT);\n  }\n  pinMode(btnPin, INPUT_PULLUP);\n  showDigit(0);\n}\n\nvoid loop() {\n  bool reading = digitalRead(btnPin);\n\n  if (reading != lastBtnState) {\n    lastDebounceTime = millis();\n  }\n\n  if ((millis() - lastDebounceTime) > debounceDelay) {\n    // Trigger on falling edge (button pressed)\n    if (reading == LOW && lastBtnState == HIGH) {\n      count = (count + 1) % 10;\n      showDigit(count);\n    }\n  }\n\n  lastBtnState = reading;\n}\n"
