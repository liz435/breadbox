    "sketchCode": "int ledPin1 = 11;\nint ledPin2 = 10;\nint ledPin3 = 9;\nint btnPin1 = 8;\nint btnPin2 = 7;\nint btnPin3 = 6;\n\nint ledState1 = LOW;\nint ledState2 = LOW;\nint ledState3 = LOW;\n\nint lastBtn1 = HIGH;\nint lastBtn2 = HIGH;\nint lastBtn3 = HIGH;\n\nvoid setup() {\n  pinMode(ledPin1, OUTPUT);\n  pinMode(ledPin2, OUTPUT);\n  pinMode(ledPin3, OUTPUT);\n  pinMode(btnPin1, INPUT_PULLUP);\n  pinMode(btnPin2, INPUT_PULLUP);\n  pinMode(btnPin3, INPUT_PULLUP);\n}\n\nvoid loop() {\n  int btn1 = digitalRead(btnPin1);\n  if (btn1 == LOW && lastBtn1 == HIGH) {\n    ledState1 = (ledState1 == LOW) ? HIGH : LOW;\n    digitalWrite(ledPin1, ledState1);\n  }\n  lastBtn1 = btn1;\n\n  int btn2 = digitalRead(btnPin2);\n  if (btn2 == LOW && lastBtn2 == HIGH) {\n    ledState2 = (ledState2 == LOW) ? HIGH : LOW;\n    digitalWrite(ledPin2, ledState2);\n  }\n  lastBtn2 = btn2;\n\n  int btn3 = digitalRead(btnPin3);\n  if (btn3 == LOW && lastBtn3 == HIGH) {\n    ledState3 = (ledState3 == LOW) ? HIGH : LOW;\n    digitalWrite(ledPin3, ledState3);\n  }\n  lastBtn3 = btn3;\n\n  delay(20);\n}",
