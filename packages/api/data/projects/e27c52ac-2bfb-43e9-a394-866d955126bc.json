    "sketchCode": "\nint counter = 0;\n\nint btnAddPin = 9;\nint btnSubPin = 10;\nint potPin = 14;\n\nint lastAddState = HIGH;\nint lastSubState = HIGH;\n\nint segmentPins[7] = {2, 3, 4, 5, 6, 7, 8};\n\nvoid setup() {\n  pinMode(btnAddPin, INPUT_PULLUP);\n  pinMode(btnSubPin, INPUT_PULLUP);\n  pinMode(potPin, INPUT);\n  for (int i = 0; i < 7; i++) {\n    pinMode(segmentPins[i], OUTPUT);\n  }\n  displayDigit(0);\n}\n\nvoid loop() {\n  int addState = digitalRead(btnAddPin);\n  int subState = digitalRead(btnSubPin);\n  \n  // Read potentiometer and map to 0-9\n  int potValue = analogRead(potPin);\n  int potCounter = map(potValue, 0, 1023, 0, 9);\n  \n  // Button: increment\n  if (addState == LOW && lastAddState == HIGH) {\n    if (counter < 9) {\n      counter++;\n      displayDigit(counter);\n    }\n    delay(20);\n  }\n\n  // Button: decrement\n  if (subState == LOW && lastSubState == HIGH) {\n    if (counter > 0) {\n      counter--;\n      displayDigit(counter);\n    }\n    delay(20);\n  }\n  \n  // Potentiometer: directly set display\n  if (potCounter != counter) {\n    counter = potCounter;\n    displayDigit(counter);\n  }\n\n  lastAddState = addState;\n  lastSubState = subState;\n  delay(10);\n}\n\nvoid displayDigit(int digit) {\n  int a = 0, b = 0, c = 0, d = 0, e = 0, f = 0, g = 0;\n  \n  if (digit == 0) { a = 1; b = 1; c = 1; d = 1; e = 1; f = 1; g = 0; }\n  else if (digit == 1) { a = 0; b = 1; c = 1; d = 0; e = 0; f = 0; g = 0; }\n  else if (digit == 2) { a = 1; b = 1; c = 0; d = 1; e = 1; f = 0; g = 1; }\n  else if (digit == 3) { a = 1; b = 1; c = 1; d = 1; e = 0; f = 0; g = 1; }\n  else if (digit == 4) { a = 0; b = 1; c = 1; d = 0; e = 0; f = 1; g = 1; }\n  else if (digit == 5) { a = 1; b = 0; c = 1; d = 1; e = 0; f = 1; g = 1; }\n  else if (digit == 6) { a = 1; b = 0; c = 1; d = 1; e = 1; f = 1; g = 1; }\n  else if (digit == 7) { a = 1; b = 1; c = 1; d = 0; e = 0; f = 0; g = 0; }\n  else if (digit == 8) { a = 1; b = 1; c = 1; d = 1; e = 1; f = 1; g = 1; }\n  else if (digit == 9) { a = 1; b = 1; c = 1; d = 1; e = 0; f = 1; g = 1; }\n  \n  digitalWrite(segmentPins[0], a);\n  digitalWrite(segmentPins[1], b);\n  digitalWrite(segmentPins[2], c);\n  digitalWrite(segmentPins[3], d);\n  digitalWrite(segmentPins[4], e);\n  digitalWrite(segmentPins[5], f);\n  digitalWrite(segmentPins[6], g);\n}\n",
