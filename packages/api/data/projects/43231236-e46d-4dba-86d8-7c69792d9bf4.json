        "data": {
          "tint": "#ff0000",
          "width": 50,
          "height": 20,
          "sceneX": -150,
          "sceneY": -100,
          "script": "const SPEED = 100;\nconst WRAP_LEFT = -420, WRAP_RIGHT = 420;\nconst PLAYER_HW = 12, PLAYER_HH = 12;\nconst CAR_HW = 25, CAR_HH = 10;\n\n// Move left\nself.x -= SPEED * dt;\n\n// Wrap around\nif (self.x < WRAP_LEFT) self.x = WRAP_RIGHT;\n\n// Collision with player\nlet player = entities.get('Player');\nif (player) {\n  let dx = Math.abs(self.x - player.x);\n  let dy = Math.abs(self.y - player.y);\n  if (dx < CAR_HW + PLAYER_HW && dy < CAR_HH + PLAYER_HH) {\n    player.x = 0;\n    player.y = 250;\n    state.best_y = 250;\n    console.log('HIT! Reset to start');\n  }\n}"
        }
      },
