        "data": {
          "tint": "#00ff00",
          "width": 24,
          "height": 24,
          "sceneX": 0,
          "sceneY": 250,
          "script": "const STEP = 30;\nconst MIN_X = -380, MAX_X = 380;\nconst MIN_Y = -280, MAX_Y = 280;\n\nif (!state.best_y) state.best_y = 250;\n\nlet moved = false;\nif (Input.isKeyPressed('ArrowUp')) {\n  self.y -= STEP;\n  moved = true;\n}\nif (Input.isKeyPressed('ArrowDown')) {\n  self.y += STEP;\n  moved = true;\n}\nif (Input.isKeyPressed('ArrowLeft')) {\n  self.x -= STEP;\n  moved = true;\n}\nif (Input.isKeyPressed('ArrowRight')) {\n  self.x += STEP;\n  moved = true;\n}\n\nif (moved) {\n  self.x = Math.max(MIN_X, Math.min(MAX_X, self.x));\n  self.y = Math.max(MIN_Y, Math.min(MAX_Y, self.y));\n  if (self.y < state.best_y) state.best_y = self.y;\n}\n\n// Check win condition (reached top)\nif (self.y <= -260) {\n  console.log('WIN!');\n  self.x = 0;\n  self.y = 250;\n  state.best_y = 250;\n}"
        }
      },
