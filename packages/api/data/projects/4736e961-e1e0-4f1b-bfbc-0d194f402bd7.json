    "serialOutput": [],
    "sketchCode": "int btnPins[3] = {9, 10, 8};\nint ledPins[3] = {13, 12, 11};\nint ledStates[3] = {LOW, LOW, LOW};\nint lastBtnState[3] = {HIGH, HIGH, HIGH};\n\nvoid setup() {\n  for (int i = 0; i < 3; i++) {\n    pinMode(btnPins[i], INPUT_PULLUP);\n    pinMode(ledPins[i], OUTPUT);\n    digitalWrite(ledPins[i], LOW);\n  }\n}\n\nvoid loop() {\n  for (int i = 0; i < 3; i++) {\n    int currentBtnState = digitalRead(btnPins[i]);\n    \n    // Detect button press (HIGH to LOW transition)\n    if (currentBtnState == LOW && lastBtnState[i] == HIGH) {\n      // Toggle the LED state\n      ledStates[i] = !ledStates[i];\n      digitalWrite(ledPins[i], ledStates[i]);\n      delay(20); // Debounce delay\n    }\n    \n    lastBtnState[i] = currentBtnState;\n  }\n  delay(10);\n}",
