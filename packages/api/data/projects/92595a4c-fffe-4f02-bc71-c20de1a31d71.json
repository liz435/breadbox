      "7d04dc1e-48f3-4e19-8e51-fdae9300492c": {
        "id": "7d04dc1e-48f3-4e19-8e51-fdae9300492c",
        "type": "sprite",
        "name": "Player",
        "x": 0,
        "y": 0,
        "width": 200,
        "height": 150,
        "ports": [
          {
            "id": "shader_in",
            "name": "Shader",
            "direction": "in",
            "dataType": "shader"
          },
          {
            "id": "material_in",
            "name": "Material",
            "direction": "in",
            "dataType": "material"
          },
          {
            "id": "texture_out",
            "name": "Texture",
            "direction": "out",
            "dataType": "texture"
          },
          {
            "id": "entity_out",
            "name": "Entity",
            "direction": "out",
            "dataType": "entity"
          }
        ],
        "data": {
          "tint": "#00AA00",
          "width": 20,
          "height": 20,
          "sceneX": 0,
          "sceneY": 260,
          "script": "// Initialize game state on first frame\nif (!state.initialized) {\n  state.score = 0;\n  state.lives = 3;\n  state.gameOver = false;\n  state.initialized = true;\n}\n\n// Player movement - responds to arrow key presses\nconst MOVE_DIST = 20;\nconst MAX_X = 400;\nconst MIN_X = -400;\nconst MAX_Y = 280;\nconst MIN_Y = -280;\n\nif (Input.isKeyPressed(\"ArrowUp\")) {\n  self.y -= MOVE_DIST;\n}\nif (Input.isKeyPressed(\"ArrowDown\")) {\n  self.y += MOVE_DIST;\n}\nif (Input.isKeyPressed(\"ArrowLeft\")) {\n  self.x -= MOVE_DIST;\n}\nif (Input.isKeyPressed(\"ArrowRight\")) {\n  self.x += MOVE_DIST;\n}\n\n// Bounds checking\nif (self.x > MAX_X) self.x = MAX_X;\nif (self.x < MIN_X) self.x = MIN_X;\nif (self.y > MAX_Y) self.y = MAX_Y;\nif (self.y < MIN_Y) self.y = MIN_Y;\n\n// Check collision with all cars\nconst carNames = ['Car_R1_1', 'Car_R1_2', 'Car_R1_3', \n                   'Car_R2_1', 'Car_R2_2', 'Car_R2_3',\n                   'Car_R3_1', 'Car_R3_2', 'Car_R3_3',\n                   'Car_R4_1', 'Car_R4_2', 'Car_R4_3',\n                   'Car_R5_1', 'Car_R5_2', 'Car_R5_3'];\n\nlet hitCar = false;\nfor (let carName of carNames) {\n  let car = entities.get(carName);\n  if (car) {\n    // AABB collision: abs(dx) < 35 && abs(dy) < 25\n    let dx = Math.abs(self.x - car.x);\n    let dy = Math.abs(self.y - car.y);\n    if (dx < 35 && dy < 25) {\n      hitCar = true;\n      break;\n    }\n  }\n}\n\n// Handle collision\nif (hitCar) {\n  state.lives -= 1;\n  self.x = 0;\n  self.y = 260;\n  if (state.lives <= 0) {\n    state.gameOver = true;\n  }\n}\n\n// Check win condition\nif (self.y < -260) {\n  state.score += 1;\n  self.x = 0;\n  self.y = 260;\n}"
        }
      },
