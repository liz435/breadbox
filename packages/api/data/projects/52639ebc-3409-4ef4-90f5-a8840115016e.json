    "serialOutput": [],
    "sketchCode": "// === Two LEDs + Pushbutton ===\n// D12 → LED1 (Red)  via 220Ω\n// D13 → LED2 (Green) via 220Ω\n// D2  ← Button with 10kΩ pull-down to GND\n\nconst int LED1_PIN   = 12;\nconst int LED2_PIN   = 13;\nconst int BUTTON_PIN =  2;\n\nvoid setup() {\n  pinMode(LED1_PIN,   OUTPUT);\n  pinMode(LED2_PIN,   OUTPUT);\n  pinMode(BUTTON_PIN, INPUT);   // pull-down resistor on board\n  Serial.begin(9600);\n  Serial.println(\"Circuit ready. Press button to toggle LEDs.\");\n}\n\nvoid loop() {\n  int btnState = digitalRead(BUTTON_PIN);\n\n  if (btnState == HIGH) {\n    // Button pressed: both LEDs ON\n    digitalWrite(LED1_PIN, HIGH);\n    digitalWrite(LED2_PIN, HIGH);\n    Serial.println(\"Button pressed  → LEDs ON\");\n  } else {\n    // Button released: LEDs alternate blink\n    digitalWrite(LED1_PIN, HIGH);\n    digitalWrite(LED2_PIN, LOW);\n    delay(400);\n    digitalWrite(LED1_PIN, LOW);\n    digitalWrite(LED2_PIN, HIGH);\n    delay(400);\n  }\n}",
    "customLibraries": {}
