    "sketchCode": "// 5 LEDs flashing in sequence\n\nconst int LED_RED = 9;\nconst int LED_YELLOW = 10;\nconst int LED_GREEN = 11;\nconst int LED_BLUE = 12;\nconst int LED_PURPLE = 13;\n\nconst int DELAY_MS = 300;\n\nvoid setup() {\n  pinMode(LED_RED, OUTPUT);\n  pinMode(LED_YELLOW, OUTPUT);\n  pinMode(LED_GREEN, OUTPUT);\n  pinMode(LED_BLUE, OUTPUT);\n  pinMode(LED_PURPLE, OUTPUT);\n}\n\nvoid loop() {\n  // Flash each LED in sequence\n  digitalWrite(LED_RED, HIGH);\n  delay(DELAY_MS);\n  digitalWrite(LED_RED, LOW);\n  \n  digitalWrite(LED_YELLOW, HIGH);\n  delay(DELAY_MS);\n  digitalWrite(LED_YELLOW, LOW);\n  \n  digitalWrite(LED_GREEN, HIGH);\n  delay(DELAY_MS);\n  digitalWrite(LED_GREEN, LOW);\n  \n  digitalWrite(LED_BLUE, HIGH);\n  delay(DELAY_MS);\n  digitalWrite(LED_BLUE, LOW);\n  \n  digitalWrite(LED_PURPLE, HIGH);\n  delay(DELAY_MS);\n  digitalWrite(LED_PURPLE, LOW);\n  \n  delay(100); // Pause before next cycle\n}\n",
