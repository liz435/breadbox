    "serialOutput": [],
    "sketchCode": "int counter = 0;\nint btnIncPin = 9;\nint btnDecPin = 10;\nint lastIncState = HIGH;\nint lastDecState = HIGH;\n\nint segA = 2, segB = 3, segC = 4, segD = 5, segE = 6, segF = 7, segG = 8;\n\nvoid setup() {\n  pinMode(segA, OUTPUT);\n  pinMode(segB, OUTPUT);\n  pinMode(segC, OUTPUT);\n  pinMode(segD, OUTPUT);\n  pinMode(segE, OUTPUT);\n  pinMode(segF, OUTPUT);\n  pinMode(segG, OUTPUT);\n  pinMode(btnIncPin, INPUT_PULLUP);\n  pinMode(btnDecPin, INPUT_PULLUP);\n  displayNumber(counter);\n}\n\nvoid displayNumber(int n) {\n  int a, b, c, d, e, f, g;\n  \n  if (n == 0) {\n    a = 1; b = 1; c = 1; d = 1; e = 1; f = 1; g = 0;\n  } else if (n == 1) {\n    a = 0; b = 1; c = 1; d = 0; e = 0; f = 0; g = 0;\n  } else if (n == 2) {\n    a = 1; b = 1; c = 0; d = 1; e = 1; f = 0; g = 1;\n  } else if (n == 3) {\n    a = 1; b = 1; c = 1; d = 1; e = 0; f = 0; g = 1;\n  } else if (n == 4) {\n    a = 0; b = 1; c = 1; d = 0; e = 0; f = 1; g = 1;\n  } else if (n == 5) {\n    a = 1; b = 0; c = 1; d = 1; e = 0; f = 1; g = 1;\n  } else if (n == 6) {\n    a = 1; b = 0; c = 1; d = 1; e = 1; f = 1; g = 1;\n  } else if (n == 7) {\n    a = 1; b = 1; c = 1; d = 0; e = 0; f = 0; g = 0;\n  } else if (n == 8) {\n    a = 1; b = 1; c = 1; d = 1; e = 1; f = 1; g = 1;\n  } else if (n == 9) {\n    a = 1; b = 1; c = 1; d = 1; e = 0; f = 1; g = 1;\n  }\n  \n  digitalWrite(segA, a);\n  digitalWrite(segB, b);\n  digitalWrite(segC, c);\n  digitalWrite(segD, d);\n  digitalWrite(segE, e);\n  digitalWrite(segF, f);\n  digitalWrite(segG, g);\n}\n\nvoid loop() {\n  int incState = digitalRead(btnIncPin);\n  int decState = digitalRead(btnDecPin);\n  \n  if (incState == LOW && lastIncState == HIGH) {\n    if (counter < 9) {\n      counter++;\n    }\n    displayNumber(counter);\n    delay(50);\n  }\n  \n  if (decState == LOW && lastDecState == HIGH) {\n    if (counter > 0) {\n      counter--;\n    }\n    displayNumber(counter);\n    delay(50);\n  }\n  \n  lastIncState = incState;\n  lastDecState = decState;\n  delay(10);\n}\n",
