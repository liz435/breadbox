      "5bde95c5-14f2-4685-9dde-664491c36061": {
        "id": "5bde95c5-14f2-4685-9dde-664491c36061",
        "type": "sprite",
        "name": "Player",
        "x": 0,
        "y": 0,
        "width": 200,
        "height": 150,
        "ports": [
          {
            "id": "shader_in",
            "name": "Shader",
            "direction": "in",
            "dataType": "shader"
          },
          {
            "id": "material_in",
            "name": "Material",
            "direction": "in",
