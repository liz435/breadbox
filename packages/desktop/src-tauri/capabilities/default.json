{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core window permissions plus permission to launch the bundled `dreamer` server sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/dreamer", "sidecar": true, "args": true }]
    }
  ]
}
