{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Breadbox",
  "version": "0.1.0",
  "identifier": "com.breadbox.desktop",
  "build": {
    "frontendDist": "../splash",
    "beforeDevCommand": "bun run prepare:sidecar",
    "beforeBuildCommand": "bun run prepare:sidecar --force"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Breadbox",
        "width": 1280,
        "height": 832,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark",
        "backgroundColor": "#0a0a0a",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxNkExNjkwMEJBMUIyOEMKUldTTXNxRUxrQlpxd1ZRYzduTDZoN0k5eGFGWWViZzV2ZTVFVEFWOVpqeTNCZXRKa0RReTBUaHkK",
      "endpoints": [
        "https://github.com/liz435/breadbox/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "shortDescription": "AI Arduino circuit builder",
    "longDescription": "Breadbox is an AI-assisted Arduino circuit builder. The desktop app runs the local server and renders the web UI in a native window.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/breadbox", "binaries/arduino-cli"]
  }
}
