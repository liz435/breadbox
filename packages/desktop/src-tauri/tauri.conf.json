{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dreamer",
  "version": "0.1.0",
  "identifier": "com.dreamer.desktop",
  "build": {
    "frontendDist": "../splash",
    "beforeDevCommand": "bun run prepare:sidecar",
    "beforeBuildCommand": "bun run prepare:sidecar --force"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dreamer",
        "width": 1280,
        "height": 832,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark",
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "AI Arduino circuit builder",
    "longDescription": "Dreamer is an AI-assisted Arduino circuit builder. The desktop app runs the local server and renders the web UI in a native window.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/dreamer", "binaries/arduino-cli"]
  }
}
