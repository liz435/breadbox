  "serialOutput": [],
  "sketchCode": "// Example: NeoPixel Rainbow Chase\n// Cycle rainbow colors on a WS2812 strip on pin 6.\n// Uses external 5V power supply for the LEDs.\n\n#include <Adafruit_NeoPixel.h>\n\n#define PIN 6\n#define NUM_LEDS 8\n\nAdafruit_NeoPixel strip(NUM_LEDS, PIN, NEO_GRB + NEO_KHZ800);\n\nvoid setup() {\n  strip.begin();\n  strip.setBrightness(50);\n  strip.show();\n}\n\nvoid loop() {\n  for (int i = 0; i < NUM_LEDS; i++) {\n    int hue = (i * 65536L / NUM_LEDS) + (millis() * 10);\n    strip.setPixelColor(i, strip.gamma32(strip.ColorHSV(hue)));\n  }\n  strip.show();\n  delay(20);\n}\n",
