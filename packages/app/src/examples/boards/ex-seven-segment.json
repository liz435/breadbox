  "serialOutput": [],
  "sketchCode": "// Example: 7-Segment Display Counter\n// Count from 0-9 on a common-cathode 7-segment display.\n// Segments a-g on pins 2-8.\n// Each byte encodes segments a-g as bits 0-6.\n\nint segPins[] = {2, 3, 4, 5, 6, 7, 8};\nbyte digits[] = {0x3F, 0x06, 0x5B, 0x4F, 0x66, 0x6D, 0x7D, 0x07, 0x7F, 0x6F};\n\nvoid showDigit(int d) {\n  for (int i = 0; i < 7; i++) {\n    digitalWrite(segPins[i], (digits[d] >> i) & 1);\n  }\n}\n\nvoid setup() {\n  for (int i = 0; i < 7; i++) {\n    pinMode(segPins[i], OUTPUT);\n  }\n}\n\nvoid loop() {\n  for (int d = 0; d < 10; d++) {\n    showDigit(d);\n    delay(1000);\n  }\n}\n",
