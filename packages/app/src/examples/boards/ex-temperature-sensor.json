  "serialOutput": [],
  "sketchCode": "// Example: Temperature Sensor (TMP36)\n// Read analog value on A0, convert to Celsius.\n\nint sensorPin = A0;\n\nvoid setup() {\n  Serial.begin(9600);\n}\n\nvoid loop() {\n  int reading = analogRead(sensorPin);\n  float voltage = reading * (5.0 / 1024.0);\n  float tempC = (voltage - 0.5) * 100.0;\n  Serial.print(\"Temp: \");\n  Serial.print(tempC);\n  Serial.println(\" C\");\n  delay(1000);\n}\n",
