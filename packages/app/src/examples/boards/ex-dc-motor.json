  "serialOutput": [],
  "sketchCode": "// Example: DC Motor Speed Ramp\n// Gradually ramp motor speed up and down using PWM.\n// Uses external 5V power supply for the motor.\n\nint motorPin = 9;\n\nvoid setup() {\n  pinMode(motorPin, OUTPUT);\n}\n\nvoid loop() {\n  for (int speed = 0; speed <= 255; speed += 5) {\n    analogWrite(motorPin, speed);\n    delay(30);\n  }\n  for (int speed = 255; speed >= 0; speed -= 5) {\n    analogWrite(motorPin, speed);\n    delay(30);\n  }\n  delay(500);\n}\n",
