  "serialOutput": [],
  "sketchCode": "// Example: Shift Register LED Chaser\n// Use a 74HC595 to chase LEDs with shiftOut.\n\nint dataPin = 8;\nint clockPin = 11;\nint latchPin = 12;\n\nvoid setup() {\n  pinMode(dataPin, OUTPUT);\n  pinMode(clockPin, OUTPUT);\n  pinMode(latchPin, OUTPUT);\n}\n\nvoid loop() {\n  for (int i = 0; i < 8; i++) {\n    byte pattern = 1 << i;\n    digitalWrite(latchPin, LOW);\n    shiftOut(dataPin, clockPin, MSBFIRST, pattern);\n    digitalWrite(latchPin, HIGH);\n    delay(200);\n  }\n}\n",
