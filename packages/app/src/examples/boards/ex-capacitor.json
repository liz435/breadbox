  "serialOutput": [],
  "sketchCode": "// Example: Capacitor Charge/Discharge\n// Pin 7 charges a capacitor through a 1kΩ resistor.\n// The LED is in parallel with the cap — it shows the\n// voltage across the cap. When pin 7 goes LOW, the cap\n// discharges through the LED, which fades out slowly.\n\nvoid setup() {\n  pinMode(7, OUTPUT);\n  Serial.begin(9600);\n}\n\nvoid loop() {\n  digitalWrite(7, HIGH);  // charge the cap\n  Serial.println(\"Charging...\");\n  delay(3000);\n  digitalWrite(7, LOW);   // cap discharges through LED\n  Serial.println(\"Discharging...\");\n  delay(3000);\n}\n",
